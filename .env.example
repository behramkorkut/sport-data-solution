# ============================================================
# Sport Data Solution — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=sport_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=sport_data
POSTGRES_PORT=5432

# ---------- Google Maps API ----------
# Required for distance validation (home-to-office)
# Get your key at: https://console.cloud.google.com
# Enable: Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ---------- Slack ----------
# Required for activity notifications
# Create an Incoming Webhook at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX